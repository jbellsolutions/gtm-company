# ============================================================
# GTM Company -- Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
# ============================================================

# === Required: Supabase ===
# Find these at: Supabase Dashboard > Project Settings > API
# Project URL (starts with https://, ends with .supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Anon/public key (safe to use client-side, starts with "eyJ...")
SUPABASE_ANON_KEY=your-anon-key-here

# === Required: Project Identity ===
# A unique kebab-case name for this GTM project (e.g., acme-corp-gtm)
# Used as the namespace in Supabase and state files
PROJECT_ID=your-project-name

# === Optional: Slack Notifications ===
# Channel where agent summaries are posted after each run
# Set to empty or remove if you don't use Slack
SLACK_CHANNEL=#gtm-ops

# === Optional: Paperclip Dashboard ===
# URL where your Paperclip dashboard is running
# Default: http://localhost:3100 (self-hosted on VPS)
# Can also be a Vercel URL if deployed there
PAPERCLIP_URL=http://localhost:3100

# UUID for your company in the Paperclip system
# Generated during dashboard setup
PAPERCLIP_COMPANY_ID=your-company-uuid

# === Optional: SmartLead (Scaled Email Sending) ===
# Get your API key at: https://app.smartlead.ai/settings/api
# Required for automated email sending beyond Gmail drafts
# Without this, all emails are created as Gmail drafts for manual review
SMARTLEAD_API_KEY=your-smartlead-key-here

# === Optional: Firecrawl (Web Scraping / Research) ===
# Get your free API key at: https://firecrawl.dev/app/api-keys
# Free tier: 500 pages/month -- enough for prospect research
# Used by cold-outreach agent for prospect company research
FIRECRAWL_API_KEY=your-firecrawl-key-here
