# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=claude-sonnet-4-5

# ── Slack ──────────────────────────────────────────────────────────────────────
# Bot User OAuth Token (xoxb-...) — from api.slack.com → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-...
# App-Level Token (xapp-...) — from api.slack.com → Basic Information → App-Level Tokens
# Required for Socket Mode (no public URL needed)
SLACK_APP_TOKEN=xapp-...
# Justin's Slack user ID — for DMs and auto-invites to client channels
JUSTIN_SLACK_USER_ID=U0123456789

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Identity (optional overrides) ─────────────────────────────────────────────
# Path to identity JSON file. Default: identities/head-of-operations.json
# IDENTITY_FILE=identities/head-of-operations.json
# Path to tools JSON file. Default: config/tools.json
# TOOLS_FILE=config/tools.json

# ── Pipeline Runner (DigitalOcean) ─────────────────────────────────────────────
# URL of the DigitalOcean pipeline runner (if running agents remotely)
# If not set, agents run locally via run-agent.sh
PIPELINE_RUNNER_URL=http://your-droplet-ip:3001
PIPELINE_API_SECRET=generate-with-openssl-rand-hex-32

# ── Repo Path (for local agent execution) ─────────────────────────────────────
# Path to the ai-integraterz repo. Default: ~/Desktop/ai-integraterz
AI_INTEGRATERZ_REPO=/Users/home/Desktop/ai-integraterz

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
